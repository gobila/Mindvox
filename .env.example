# Copy this file to .env for local development.
# Never commit real tokens or secrets.

# Required for E02/E03. Empty local value uses the didactic dev-token automatically
# when MINDVOX_PUBLIC_DEPLOYMENT=false. Set a private value only in .env when needed.
# Do not use dev-token when MINDVOX_PUBLIC_DEPLOYMENT=true; public mode treats it as missing.
MINDVOX_API_TOKEN=
MINDVOX_MAX_UPLOAD_MB=500

# Public deployment hardening. Keep false for local classroom demos.
MINDVOX_PUBLIC_DEPLOYMENT=false
MINDVOX_ENABLE_DOCS=true
MINDVOX_TRUSTED_HOSTS=

# Normally inferred or set by startup profiles: dev, contract, or prod.
MINDVOX_RUNTIME_PROFILE=

# Use "real" for the actual STT engine and "contract" only for tests or controlled demos.
MINDVOX_TRANSCRIPTION_MODE=real
MINDVOX_TRANSCRIPTION_BACKEND=auto
MINDVOX_TRANSCRIPTION_MODEL=mlx-community/whisper-large-v3-turbo-fp16
MINDVOX_TRANSCRIPTION_FALLBACK_MODEL=turbo
MINDVOX_TRANSCRIPTION_OUTPUT_DIR=outputs/transcriptions
MINDVOX_TRANSCRIPTION_TEXT_OUTPUT_DIR=outputs/human/transcriptions

# E03 post-processing mode:
# - "auto" follows MINDVOX_TRANSCRIPTION_MODE: contract -> contract, real -> local.
# - "contract" validates the HTTP contract without a real LLM.
# - "local" uses a local OpenAI-compatible server, such as llama-server.
# - "provider" uses an external OpenAI-compatible provider.
MINDVOX_POSTPROCESSING_MODE=auto
MINDVOX_POSTPROCESSING_MAX_INPUT_CHARS=150000

# Optional high-fidelity pipeline for long E03 transcripts.
# Keep "off" to preserve the single-call behavior. Use "tfidf" to enable
# pre-audit -> semantic chunks -> chunk processing -> deterministic merge.
MINDVOX_POSTPROCESSING_CHUNKING_MODE=tfidf
MINDVOX_POSTPROCESSING_CHUNKING_MIN_CHARS=20000
MINDVOX_POSTPROCESSING_CHUNK_TARGET_TOKENS=5000
MINDVOX_POSTPROCESSING_PRE_AUDIT_ENABLED=true
MINDVOX_POSTPROCESSING_FINAL_AUDIT_ENABLED=true

# E03 LLM settings for the default real local mode.
# For provider mode, set MINDVOX_POSTPROCESSING_MODE=provider and replace these values
# with the provider configuration in your private .env.
MINDVOX_LLM_PROVIDER=local
MINDVOX_LLM_BASE_URL=http://127.0.0.1:8080/v1
MINDVOX_LLM_ALLOWED_PROVIDER_HOSTS=
MINDVOX_LLM_MODEL=qwen35a3b-q8
MINDVOX_LLM_API_KEY=
MINDVOX_LLM_MAX_OUTPUT_TOKENS=20000
MINDVOX_LLM_TIMEOUT_SECONDS=1200

# Local LLM automation for E03 real local mode.
# When MINDVOX_POSTPROCESSING_MODE resolves to "local", the app tries to start
# llama-server automatically unless MINDVOX_LOCAL_LLM_AUTOSTART=false.
MINDVOX_LOCAL_LLM_AUTOSTART=true
MINDVOX_LLAMA_SERVER_PATH=
MINDVOX_LOCAL_LLM_MODEL_PATH=
MINDVOX_LLAMA_SERVER_CTX_SIZE=65536
MINDVOX_LLAMA_SERVER_GPU_LAYERS=99
MINDVOX_LLAMA_SERVER_PARALLEL=1
MINDVOX_LLAMA_SERVER_STARTUP_TIMEOUT_SECONDS=240

# Local persistence for E03 processed outputs and automatic retry queue.
MINDVOX_PROCESSED_TRANSCRIPTION_OUTPUT_DIR=outputs/processed_transcriptions
MINDVOX_PROCESSED_TRANSCRIPTION_MARKDOWN_OUTPUT_DIR=outputs/human/processed_transcriptions
MINDVOX_PROCESSED_TRANSCRIPTION_REJECTED_OUTPUT_DIR=outputs/processed_transcriptions/rejected
MINDVOX_PROCESSED_TRANSCRIPTION_REJECTED_MARKDOWN_OUTPUT_DIR=outputs/human/processed_transcriptions/rejected
MINDVOX_PROCESSED_TRANSCRIPTION_QUEUE_ENABLED=true
MINDVOX_PROCESSED_TRANSCRIPTION_QUEUE_RETRY_SECONDS=60
MINDVOX_PROCESSED_TRANSCRIPTION_QUEUE_MAX_ATTEMPTS=3

# E03 Study Package.
MINDVOX_E03_STUDY_PACKAGE_OUTPUT_DIR=outputs/study_packages
MINDVOX_E03_ACTIVE_COURSE_STORE=outputs/config/e03_courses.json

# Optional Obsidian export. SQLite remains the intended relational memory target.
# When enabled, v1 only creates a new deterministic Student Vault; it does not
# import, repair, or validate an existing Vault.
MINDVOX_E03_OBSIDIAN_EXPORT_ENABLED=false
MINDVOX_E03_OBSIDIAN_VAULTS_BASE_DIR=
MINDVOX_E03_OBSIDIAN_VAULT_CREATE_ONLY=true
